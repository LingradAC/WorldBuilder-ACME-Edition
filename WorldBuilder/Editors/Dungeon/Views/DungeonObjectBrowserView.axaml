<UserControl
    x:Class="WorldBuilder.Editors.Dungeon.Views.DungeonObjectBrowserView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WorldBuilder.Editors.Dungeon"
    xmlns:lvm="using:WorldBuilder.Editors.Landscape.ViewModels"
    d:DesignHeight="500"
    d:DesignWidth="280"
    x:CompileBindings="True"
    x:DataType="vm:DungeonObjectBrowserViewModel"
    mc:Ignorable="d">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="4,2">
            <TextBox
                Watermark="Search by name or hex ID"
                Text="{Binding SearchText}"
                FontSize="11"
                Padding="4,3" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <CheckBox Content="Setups" IsChecked="{Binding ShowSetups}" FontSize="11" Padding="2,0" />
                <CheckBox Content="GfxObj" IsChecked="{Binding ShowGfxObjs}" FontSize="11" Padding="2,0" />
                <CheckBox Content="Weenies" IsChecked="{Binding ShowWeenies}" FontSize="11" Padding="2,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                <Button Content="Load Weenies (DB)"
                        Command="{Binding LoadWeeniesFromDbCommand}"
                        IsEnabled="{Binding !IsLoadingWeenies}"
                        FontSize="10" Padding="6,3"
                        Background="Transparent" BorderThickness="0" Foreground="#6ec07a" />
            </StackPanel>

            <TextBlock
                FontSize="10"
                Foreground="{DynamicResource SystemBaseMediumColor}"
                Opacity="0.7"
                Text="{Binding Status}"
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer>
            <StackPanel Margin="0,0,0,32">
                <ItemsControl ItemsSource="{Binding FilteredItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="lvm:ObjectBrowserItem">
                            <Button
                                Margin="3"
                                Padding="2"
                                Command="{Binding $parent[UserControl].((vm:DungeonObjectBrowserViewModel)DataContext).SelectForPlacementCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="{Binding Tags}"
                                Focusable="False"
                                HorizontalContentAlignment="Center">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <Panel Width="80" Height="80">
                                        <Border
                                            Background="#FF2A2A2A"
                                            CornerRadius="2"
                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}" />
                                        <Image
                                            Width="80"
                                            Height="80"
                                            Source="{Binding Thumbnail}"
                                            Stretch="Uniform"
                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </Panel>
                                    <TextBlock
                                        Text="{Binding DisplayId}"
                                        FontSize="9"
                                        HorizontalAlignment="Center"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"
                                        MaxHeight="30"
                                        MaxWidth="84" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button
                    Content="Show more..."
                    Command="{Binding ShowMoreCommand}"
                    IsVisible="{Binding HasMore}"
                    HorizontalAlignment="Center"
                    Margin="4,8"
                    Padding="16,6"
                    FontSize="11"
                    Background="Transparent"
                    BorderThickness="1"
                    BorderBrush="#3a2d52"
                    Foreground="#8a7a9e" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
