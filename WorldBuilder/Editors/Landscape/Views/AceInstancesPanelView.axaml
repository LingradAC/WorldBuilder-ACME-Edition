<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WorldBuilder.Editors.Landscape"
             xmlns:conv="clr-namespace:WorldBuilder.Lib.Converters"
             xmlns:wbvm="using:WorldBuilder.ViewModels"
             x:Class="WorldBuilder.Editors.Landscape.Views.AceInstancesPanelView"
             x:DataType="vm:AceInstancesPanelViewModel">
    <ScrollViewer>
        <StackPanel Spacing="10" Margin="10">
            <TextBlock Text="ACE Instances (World)"
                       FontSize="13" FontWeight="SemiBold" Foreground="#d4a843" />
            <TextBlock Text="Place generators, items, or portals in the world. Configure Settings → ACE Database. Placements export to landblock_instances.sql."
                       FontSize="10" Foreground="#6a5a7e" TextWrapping="Wrap" />

            <Border Background="#1a1a2e" BorderBrush="#2a2a4e" BorderThickness="1" Padding="8" CornerRadius="4"
                    IsVisible="{Binding WeeniePicker, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Browse weenies" FontSize="10" FontWeight="SemiBold" Foreground="#8a7a9e" />
                    <TextBox Text="{Binding WeeniePicker.SearchText}" Watermark="Search name (optional)" FontSize="11" Padding="4,3" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Load weenies" Command="{Binding WeeniePicker.LoadWeeniesCommand}"
                                IsEnabled="{Binding !WeeniePicker.IsLoading}" Padding="8,4" FontSize="11" />
                        <Button Content="Test connection" Command="{Binding WeeniePicker.TestConnectionCommand}"
                                IsEnabled="{Binding !WeeniePicker.IsLoading}" Padding="8,4" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding WeeniePicker.StatusMessage}" FontSize="10" Foreground="#8a7a9e" TextTrimming="CharacterEllipsis" />
                    <ListBox ItemsSource="{Binding WeeniePicker.Weenies}"
                             SelectedItem="{Binding WeeniePicker.SelectedWeenie}"
                             MaxHeight="100" FontSize="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="wbvm:WeeniePickerItem">
                                <TextBlock Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Button Content="Place at current camera position" Command="{Binding PlaceAtCurrentPositionCommand}"
                    Padding="8,6" FontSize="11" HorizontalAlignment="Left"
                    ToolTip.Tip="Uses perspective camera position; adds to current landblock as outdoor cell 1" />

            <TextBlock Text="Placements (saved to project)" FontSize="11" Foreground="#8a7a9e" />
            <ItemsControl ItemsSource="{Binding Placements}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:OutdoorPlacementItemViewModel">
                        <Border Background="#1a0e30" BorderBrush="#2a1d42" BorderThickness="1" Padding="6,4" Margin="0,0,0,4" CornerRadius="3">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="&#x2715;" Foreground="#cc6666" Padding="4,0"
                                        Command="{Binding $parent[UserControl].DataContext.RemovePlacementCommand}"
                                        CommandParameter="{Binding Index}"
                                        ToolTip.Tip="Remove" />
                                <TextBlock Text="{Binding DisplayText}" FontSize="10" Foreground="#c0b0d8" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
