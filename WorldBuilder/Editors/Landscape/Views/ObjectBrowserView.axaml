<UserControl
    x:Class="WorldBuilder.Editors.Landscape.Views.ObjectBrowserView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WorldBuilder.Editors.Landscape.ViewModels"
    d:DesignHeight="500"
    d:DesignWidth="280"
    x:CompileBindings="True"
    x:DataType="vm:ObjectBrowserViewModel"
    mc:Ignorable="d">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="4,2">
            <TextBox
                Watermark="Search by name or hex ID"
                Text="{Binding SearchText}"
                FontSize="11"
                Padding="4,3" />

            <WrapPanel Orientation="Horizontal">
                <CheckBox Content="Setups" IsChecked="{Binding ShowSetups}" FontSize="11" Padding="2,0" Margin="0,0,8,0" />
                <CheckBox Content="Buildings" IsChecked="{Binding ShowBuildingsOnly}" FontSize="11" Padding="2,0" Margin="0,0,8,0" />
                <CheckBox Content="Scenery" IsChecked="{Binding ShowSceneryOnly}" FontSize="11" Padding="2,0" Margin="0,0,8,0" />
                <CheckBox Content="Weenies" IsChecked="{Binding ShowWeenies}" FontSize="11" Padding="2,0" Margin="0,0,8,0" />
                <CheckBox Content="Particles" IsChecked="{Binding ShowParticleEmitters}" FontSize="11" Padding="2,0" Margin="0,0,8,0" />
                <ToggleButton IsChecked="{Binding ShowFavoritesOnly}" Padding="4,2" FontSize="11"
                              Background="Transparent" BorderThickness="0" ToolTip.Tip="Show favorites only">
                    <Panel>
                        <TextBlock Text="&#x2605;" FontSize="14" Foreground="#c8a832"
                                   IsVisible="{Binding ShowFavoritesOnly}" />
                        <TextBlock Text="&#x2606;" FontSize="14" Foreground="#5a4a6e"
                                   IsVisible="{Binding !ShowFavoritesOnly}" />
                    </Panel>
                </ToggleButton>
            </WrapPanel>

            <Button Content="Load Weenies (DB)"
                    Command="{Binding LoadWeeniesFromDbCommand}"
                    IsEnabled="{Binding !IsLoadingWeenies}"
                    FontSize="10" Padding="6,3" Margin="0,2,0,0"
                    Background="Transparent" BorderThickness="0" Foreground="#6ec07a" />

            <!-- Place-as toggle: only relevant for weenies -->
            <Border IsVisible="{Binding ShowWeenies}"
                    Background="#110a22" BorderBrush="#2a1d42" BorderThickness="1"
                    CornerRadius="4" Padding="6,4">
                <StackPanel Spacing="4">
                    <TextBlock Text="Place weenie as:" FontSize="10" Foreground="#8a7a9e" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <RadioButton Content="Static (DAT)"
                                     IsChecked="{Binding PlaceWeenieAsInstance, Converter={x:Static BoolConverters.Not}}"
                                     FontSize="10" Foreground="#c0b0d8"
                                     ToolTip.Tip="Embeds the weenie's model as a static object in the DAT. Fast but not server-side." />
                        <RadioButton Content="DB Instance"
                                     IsChecked="{Binding PlaceWeenieAsInstance}"
                                     FontSize="10" Foreground="#d4a843"
                                     ToolTip.Tip="Creates an ACE landblock_instance entry exported to SQL. The weenie lives on the server." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock
                FontSize="10"
                Foreground="{DynamicResource SystemBaseMediumColor}"
                Opacity="0.7"
                Text="{Binding Status}"
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer>
            <StackPanel Margin="0,0,0,32">
                <ItemsControl ItemsSource="{Binding FilteredItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ObjectBrowserItem">
                            <Button
                                Margin="3"
                                Padding="2"
                                Command="{Binding $parent[UserControl].((vm:ObjectBrowserViewModel)DataContext).SelectForPlacementCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="{Binding Tags}"
                                Focusable="False"
                                HorizontalContentAlignment="Center">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <Panel Width="80" Height="80">
                                        <Border
                                            Background="#FF2A2A2A"
                                            CornerRadius="2"
                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}" />
                                        <Image
                                            Width="80"
                                            Height="80"
                                            Source="{Binding Thumbnail}"
                                            Stretch="Uniform"
                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <Button CornerRadius="0,4,0,0" Padding="2,0"
                                                Background="#CC1a0e30" BorderThickness="0"
                                                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                Command="{Binding $parent[UserControl].((vm:ObjectBrowserViewModel)DataContext).ToggleFavoriteCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Toggle favorite" Cursor="Hand" Focusable="False">
                                            <Panel>
                                                <TextBlock Text="&#x2605;" FontSize="12" Foreground="#c8a832"
                                                           IsVisible="{Binding IsFavorite}" />
                                                <TextBlock Text="&#x2606;" FontSize="12" Foreground="#5a4a6e"
                                                           IsVisible="{Binding !IsFavorite}" />
                                            </Panel>
                                        </Button>
                                    </Panel>
                                    <TextBlock
                                        Text="{Binding DisplayId}"
                                        FontSize="9"
                                        HorizontalAlignment="Center"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"
                                        MaxHeight="30"
                                        MaxWidth="84" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button
                    Content="Show more..."
                    Command="{Binding ShowMoreCommand}"
                    IsVisible="{Binding HasMore}"
                    HorizontalAlignment="Center"
                    Margin="4,8"
                    Padding="16,6"
                    FontSize="11"
                    Background="Transparent"
                    BorderThickness="1"
                    BorderBrush="#3a2d52"
                    Foreground="#8a7a9e" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
